import { expect, Locator, TestInfo } from "@playwright/test";
import logger from "../logging/logger";

/**
 * BaseComponent — abstract base class for all reusable UI Components in <%- project.applicationName %>.
 *
 * A Component encapsulates a bounded, reusable area of the UI — a data table, a modal
 * dialog, a search panel, a pagination control — that appears inside one or more Page Objects.
 *
 * ── Why BaseComponent exists ──────────────────────────────────────────────────
 * BasePage controls an entire screen via {@link Page}. BaseComponent controls a specific
 * DOM region via a scoped root {@link Locator}. This separation lets reusable UI widgets
 * be modelled once and composed into any Page Object that contains them:
 *
 *   class InvoicePage extends BasePage {
 *     readonly table = new InvoiceTableComponent(
 *       this.page.locator('[data-testid="invoice-table"]'),
 *       this.testInfo
 *     );
 *   }
 *
 * ── Conventions ───────────────────────────────────────────────────────────────
 * • Name subclasses after the UI element they represent
 *   e.g. InvoiceTableComponent, ConfirmModalComponent, DatePickerComponent
 * • Declare child locators as private readonly fields using {@link find}
 * • Expose interaction methods that describe intent: nextPage() not clickArrow()
 * • Keep components application-agnostic — no business rules, no domain state
 *
 * See ADR-012 for the full rationale behind this abstraction.
 *
 * Generated by pw-gen v<%- generator.version %>
 */
export abstract class BaseComponent {
    protected readonly root: Locator;
    protected readonly testInfo: TestInfo;

    /**
     * @param root     - The scoping locator that bounds this component's DOM region.
     *                   All child locators created via {@link find} are resolved relative to this.
     * @param testInfo - TestInfo from the test or fixture. Enables component screenshot attachment.
     *                   Supply the same testInfo passed to the containing Page Object.
     */
    constructor(root: Locator, testInfo: TestInfo) {
        this.root = root;
        this.testInfo = testInfo;
    }

    // ── Component-level visibility ────────────────────────────────────────────

    /**
     * Assert that this component's root element is visible in the viewport.
     * Use after navigating to a page or triggering an interaction that should reveal the component.
     */
    async expectComponentVisible(): Promise<void> {
        await expect(this.root).toBeVisible();
        logger.info(`Component visible: ${this.constructor.name}`);
    }

    /**
     * Assert that this component's root element is hidden or detached from the DOM.
     * Use after an interaction that should dismiss or collapse the component.
     */
    async expectComponentHidden(): Promise<void> {
        await expect(this.root).toBeHidden();
        logger.info(`Component hidden: ${this.constructor.name}`);
    }

    /**
     * Return true if this component's root is currently visible **at the instant of the call**.
     * Does NOT retry or wait.
     *
     * ⚠️  NEVER use as an assertion. Use {@link expectComponentVisible} instead.
     *     `isVisible()` is instant — it bypasses Playwright's auto-wait engine and will produce
     *     intermittent results on elements whose visibility transitions asynchronously.
     *
     * ✅  CORRECT — conditional branching on already-stable component state:
     *         if (await this.isVisible()) { await this.dismiss(); }
     *
     * ❌  INCORRECT — assertion use is flake-prone:
     *         expect(await this.isVisible()).toBe(true);
     *         Use instead: await this.expectComponentVisible();
     */
    async isVisible(): Promise<boolean> {
        return this.root.isVisible();
    }

    // ── Scoped element access ─────────────────────────────────────────────────

    /**
     * Return a {@link Locator} scoped to this component's root.
     *
     * Use in subclass constructors to declare child locators:
     *   private readonly saveButton = this.find('[data-testid="save"]');
     *   private readonly rows       = this.find('tbody tr');
     *
     * @param selector - CSS selector or any Playwright locator expression.
     */
    protected find(selector: string): Locator {
        return this.root.locator(selector);
    }

    // ── Wait helpers ──────────────────────────────────────────────────────────

    /**
     * Wait for a child element within this component to become visible.
     * @param locator     - The element to wait for (use {@link find} to scope it).
     * @param description - Optional human-readable name for log output.
     * @param timeout     - Maximum wait in ms (uses Playwright default when omitted).
     */
    async waitForElement(locator: Locator, description?: string, timeout?: number): Promise<void> {
        await locator.waitFor({ state: "visible", ...(timeout !== undefined && { timeout }) });
        logger.info(`Element ready: ${description ?? locator.toString()}`);
    }

    /**
     * Wait for a loading indicator inside this component to disappear.
     * Use for components with their own loading state (table refresh spinner, inline loader).
     *
     * @param indicator   - Locator of the loading element.
     * @param description - Optional human-readable name for log output.
     * @param timeout     - Maximum wait in ms (default: 30 000).
     */
    async waitForLoadingIndicator(
        indicator: Locator,
        description = "loading indicator",
        timeout = 30_000
    ): Promise<void> {
        await indicator.waitFor({ state: "hidden", timeout });
        logger.info(`${description} cleared`);
    }

    // ── Assertions ────────────────────────────────────────────────────────────

    /**
     * Assert a child element within this component is visible.
     * @param description - Optional human-readable name for log output.
     */
    async expectVisible(locator: Locator, description?: string): Promise<void> {
        await expect(locator).toBeVisible();
        logger.info(`Visible: ${description ?? locator.toString()}`);
    }

    /**
     * Assert a child element within this component is hidden or detached from the DOM.
     * @param description - Optional human-readable name for log output.
     */
    async expectHidden(locator: Locator, description?: string): Promise<void> {
        await expect(locator).toBeHidden();
        logger.info(`Hidden: ${description ?? locator.toString()}`);
    }

    /**
     * Assert a child element within this component contains the expected text (substring match).
     * @param description - Optional human-readable name for log output.
     */
    async expectText(locator: Locator, expected: string, description?: string): Promise<void> {
        await expect(locator).toContainText(expected);
        logger.info(`Text "${expected}" verified on: ${description ?? locator.toString()}`);
    }

    // ── Interactions ──────────────────────────────────────────────────────────

    /**
     * Click a child element within this component.
     * @param description - Optional human-readable name for log output.
     */
    async click(locator: Locator, description?: string): Promise<void> {
        await locator.click();
        logger.info(`Clicked: ${description ?? locator.toString()}`);
    }

    /**
     * Clear and fill a text input within this component.
     * @param description - Optional human-readable name for log output.
     */
    async fill(locator: Locator, value: string, description?: string): Promise<void> {
        await locator.fill(value);
        logger.info(`Filled ${description ?? locator.toString()}: "${value}"`);
    }

    /**
     * Select a value in a <select> element within this component.
     * @param description - Optional human-readable name for log output.
     */
    async selectOption(locator: Locator, value: string, description?: string): Promise<void> {
        await locator.selectOption(value);
        logger.info(`Selected "${value}" on: ${description ?? locator.toString()}`);
    }

    /**
     * Scroll a child element within this component into the viewport.
     * @param description - Optional human-readable name for log output.
     */
    async scrollIntoView(locator: Locator, description?: string): Promise<void> {
        await locator.scrollIntoViewIfNeeded();
        logger.info(`Scrolled into view: ${description ?? locator.toString()}`);
    }

    // ── Attachments ───────────────────────────────────────────────────────────

    /**
     * Take a screenshot of this component and attach it to the Playwright HTML report.
     *
     * Unlike {@link BasePage.takeScreenshot}, this captures only the component's bounding
     * box — not the full page — producing focused, component-level evidence artefacts.
     *
     * @param name - Filename (without extension) used in the report attachment.
     */
    async takeScreenshot(name: string): Promise<void> {
        const filePath = this.testInfo.outputPath(`${name}.png`);
        await this.root.screenshot({ path: filePath });
        await this.testInfo.attach(name, { path: filePath, contentType: "image/png" });
        logger.info(`Component screenshot attached: ${name}`);
    }
}
