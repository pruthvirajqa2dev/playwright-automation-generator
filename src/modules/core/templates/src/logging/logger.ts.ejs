import winston from "winston";

/**
 * logger — singleton Winston logger for <%- project.applicationName %>.
 *
 * Usage:
 *   import logger from "../logging/logger";
 *
 *   logger.info("User logged in");
 *   logger.error("Element not found", { locator: "#submit" });
 *   logger.debug("Response body", { body: responseJson });
 *
 * Log level is controlled by LOG_LEVEL in src/config/.env (default: info).
 * Console output is suppressed in CI workers unless LOG_LEVEL=debug.
 *
 * Generated by pw-gen v<%- generator.version %>
 */
const { combine, timestamp, printf, colorize } = winston.format;

const logFormat = printf((info) => {
    const ts    = String(info["timestamp"] ?? "");
    const level = info.level.toUpperCase().padEnd(5);
    const msg   = String(info.message ?? "");
    return `[${ts}] ${level} ${msg}`;
});

const isCI = process.env.CI === "true";

const logger = winston.createLogger({
    level: process.env.LOG_LEVEL ?? "info",
    format: combine(
        timestamp({ format: "YYYY-MM-DD HH:mm:ss" }),
        logFormat
    ),
    transports: [
        new winston.transports.Console({
            // Suppress in CI parallel workers unless explicitly enabled for debugging.
            // Set LOG_LEVEL=debug in the CI environment to see full output.
            silent: isCI && process.env.LOG_LEVEL !== "debug",
            // Colorize locally for readability; plain text in CI for log parsers.
            format: isCI
                ? combine(timestamp({ format: "YYYY-MM-DD HH:mm:ss" }), logFormat)
                : combine(timestamp({ format: "YYYY-MM-DD HH:mm:ss" }), colorize({ all: false }), logFormat),
        }),
    ],
});

export default logger;
