test.describe(`<%- project.applicationName %> — Framework Verification`, () => {
    test(
        "Playwright homepage loads and key elements are visible @smoke",
        async ({ page }, testInfo) => {
            // ── Annotations — visible in Playwright HTML report ───────────────
            test.info().annotations.push(
                { type: "Suite",        description: "Framework Verification" },
                { type: "Environment",  description: ENV.TEST_ENV },
                { type: "Generated by", description: "pw-gen v<%- generator.version %>" }
            );

            const samplePage = new SamplePage(page, testInfo);

            // ── Step 1: Navigate ──────────────────────────────────────────────
            await test.step("Open Playwright homepage", async () => {
                await samplePage.open();
                logger.info("Opened Playwright homepage");
            });

            // ── Step 2: Verify key elements ───────────────────────────────────
            await test.step("Verify homepage elements are visible", async () => {
                await samplePage.expectPageLoaded();
                await samplePage.takeScreenshot("homepage");
                logger.info("Homepage visibility verified");
            });

            // ── Step 3: Assert page title ─────────────────────────────────────
            await test.step("Verify page title", async () => {
                await samplePage.expectTitle(/Playwright/);
                logger.info("Page title verified");
            });

            // ── Step 4: Direct assertion example ─────────────────────────────
            await test.step("Verify heading text is non-empty", async () => {
                const headingText = await samplePage.getHeroHeadingText();
