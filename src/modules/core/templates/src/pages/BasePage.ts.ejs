import { expect, Locator, Page, TestInfo } from "@playwright/test";
import logger from "../logging/logger";

/**
 * BasePage — abstract base class for all Page Objects in <%- project.applicationName %>.
 *
 * Provides reusable navigation, assertion, interaction, and attachment helpers.
 * Every application Page Object must extend this class.
 *
 * ── Naming conventions ────────────────────────────────────────────────────────
 * • Name concrete subclasses after the screen/module identifier
 *   e.g. PRL300Q, RSS310Q, HomePage
 * • Declare all locators as private readonly class fields
 * • Expose business-oriented methods: submitInvoice() not clickButton3()
 * • Use test.step() in test files — not inside page-object methods
 *
 * Generated by pw-gen v<%- generator.version %>
 */
export abstract class BasePage {
    protected readonly page: Page;
    protected readonly testInfo: TestInfo;

    constructor(page: Page, testInfo: TestInfo) {
        this.page = page;
        this.testInfo = testInfo;
    }

    // ── Navigation ──────────────────────────────────────────────────────────

    /**
     * Navigate to a path relative to the configured baseURL.
     * Example: navigateTo("/invoices") → baseURL + "/invoices"
     */
    async navigateTo(urlPath: string): Promise<void> {
        await this.page.goto(urlPath);
        logger.info(`Navigated to: ${urlPath}`);
    }

    /** Wait for the DOM content to finish loading. */
    async waitForPageLoad(): Promise<void> {
        await this.page.waitForLoadState("domcontentloaded");
    }

    // ── Assertions ────────────────────────────────────────────────────────

    /**
     * Assert the page title matches an exact string or regular expression.
     */
    async expectTitle(pattern: string | RegExp): Promise<void> {
        await expect(this.page).toHaveTitle(pattern);
        logger.info(`Title verified: ${pattern.toString()}`);
    }

    /**
     * Assert the current URL matches an exact string or regular expression.
     */
    async expectURL(pattern: string | RegExp): Promise<void> {
        await expect(this.page).toHaveURL(pattern);
        logger.info(`URL verified: ${pattern.toString()}`);
    }

    /**
     * Assert a locator is visible in the viewport.
     * @param description - Optional human-readable name for log output.
     */
    async expectVisible(locator: Locator, description?: string): Promise<void> {
        await expect(locator).toBeVisible();
        logger.info(`Visible: ${description ?? locator.toString()}`);
    }

    /**
     * Assert a locator contains the expected text (substring match).
     * @param description - Optional human-readable name for log output.
     */
    async expectText(locator: Locator, expected: string, description?: string): Promise<void> {
        await expect(locator).toContainText(expected);
        logger.info(`Text "${expected}" verified on: ${description ?? locator.toString()}`);
    }

    // ── Interactions ─────────────────────────────────────────────────────

    /**
     * Click a locator.
     * @param description - Optional human-readable name for log output.
     */
    async click(locator: Locator, description?: string): Promise<void> {
        await locator.click();
        logger.info(`Clicked: ${description ?? locator.toString()}`);
    }

    /**
     * Clear and fill a text input.
     * @param description - Optional human-readable name for log output.
     */
    async fill(locator: Locator, value: string, description?: string): Promise<void> {
        await locator.fill(value);
        logger.info(`Filled ${description ?? locator.toString()}: "${value}"`);
    }

    /**
     * Select a value in a <select> element.
     * @param description - Optional human-readable name for log output.
     */
    async selectOption(locator: Locator, value: string, description?: string): Promise<void> {
        await locator.selectOption(value);
        logger.info(`Selected "${value}" on: ${description ?? locator.toString()}`);
    }

    // ── Attachments ──────────────────────────────────────────────────────

    /**
     * Take a full-page screenshot and attach it to the Playwright test report.
     * @param name - Filename (without extension) used in the report attachment.
     */
    async takeScreenshot(name: string): Promise<void> {
        const filePath = this.testInfo.outputPath(`${name}.png`);
        await this.page.screenshot({ path: filePath, fullPage: false });
        await this.testInfo.attach(name, { path: filePath, contentType: "image/png" });
        logger.info(`Screenshot attached: ${name}`);
    }
}
