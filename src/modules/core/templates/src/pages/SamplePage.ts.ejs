import { Locator, Page, TestInfo } from "@playwright/test";
import { BasePage } from "./BasePage";

/**
 * SamplePage — demonstration Page Object for the Playwright documentation site.
 *
 * ─── REPLACE THIS FILE ────────────────────────────────────────────────────────
 * This is a starter Page Object included by pw-gen to verify the generated
 * framework compiles and executes correctly. It targets https://playwright.dev.
 *
 * Replace it with a Page Object that represents the first screen of
 * <%- project.applicationName %>.
 *
 * Naming convention:
 *   • Use the screen/module code as the class name (e.g. PRL300Q, RSS310Q)
 *   • Place each Page Object in src/pages/<Module>/<ScreenCode>.ts
 *   • Extend BasePage for all shared navigation and assertion helpers
 * ─────────────────────────────────────────────────────────────────────────────
 *
 * Generated by pw-gen v<%- generator.version %>
 */
export class SamplePage extends BasePage {
    // ── Locators (private, readonly) ────────────────────────────────────────
    private readonly getStartedLink: Locator;
    private readonly heroHeading: Locator;

    constructor(page: Page, testInfo: TestInfo) {
        super(page, testInfo);
        this.getStartedLink = page.getByRole("link", { name: "Get started" });
        this.heroHeading = page.getByRole("heading", { level: 1 });
    }

    // ── Actions (public, business-oriented) ─────────────────────────────────

    /** Open the Playwright documentation homepage. */
    async open(): Promise<void> {
        await this.navigateTo("/");
        await this.waitForPageLoad();
    }

    /** Assert the homepage has loaded and key elements are visible. */
    async expectPageLoaded(): Promise<void> {
        await this.expectVisible(this.getStartedLink, "Get started link");
        await this.expectVisible(this.heroHeading, "Hero heading");
    }

    /** Return the text content of the main page heading. */
    async getHeroHeadingText(): Promise<string> {
        return await this.heroHeading.innerText();
    }
}
