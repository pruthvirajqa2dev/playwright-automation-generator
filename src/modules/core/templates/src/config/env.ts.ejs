/**
 * ENV — typed, readonly wrapper for environment variables.
 *
 * All access to process.env in test and page-object code should go through
 * this class to prevent typos and surface configuration errors early.
 *
 * Environment variables are populated by playwright.config.ts which loads
 * src/config/.env (shared) then src/config/.env.{TEST_ENV} (overrides)
 * before any test file is evaluated.
 *
 * Generated by pw-gen v<%- generator.version %>
 */
export default class ENV {
    /** Base URL of the application under test */
    static readonly URL: string = process.env.URL ?? "https://playwright.dev";

    /** Active test environment — <%- environments.names.join(" | ") %> */
    static readonly TEST_ENV: string = process.env.TEST_ENV ?? "<%- environments.default %>";

    /** Primary test user identifier */
    static readonly USERID: string | undefined = process.env.USERID;

    /** Primary test user password */
    static readonly PASSWORD: string | undefined = process.env.PASSWORD;
}
