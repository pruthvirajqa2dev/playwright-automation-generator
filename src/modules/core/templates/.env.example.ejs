# Environment configuration for <%- project.applicationName %>
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to src/config/.env and fill in your values.
# NEVER commit src/config/.env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the application under test.
# If not set, the framework defaults to https://playwright.dev (sample test only).
URL=https://your-application-url.com

# Active test environment: <%- environments.names.join(" | ") %>
TEST_ENV=<%- environments.default %>

# Test user credentials (used by credentials utility when auth module is added)
USERID=your-test-username
PASSWORD=your-test-password

# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info
