import { defineConfig, devices } from "@playwright/test";
import dotenv from "dotenv";
import path from "path";

// ── Environment loading ────────────────────────────────────────────────────
// 1. Load shared defaults from src/config/.env
dotenv.config({ path: path.resolve(__dirname, "src/config/.env") });

// 2. Determine active environment (default: <%- environments.default %>)
const TEST_ENV = process.env.TEST_ENV ?? "<%- environments.default %>";

// 3. Load environment-specific overrides (takes precedence over shared defaults)
dotenv.config({
    path: path.resolve(__dirname, `src/config/.env.${TEST_ENV}`),
    override: true,
});

const isCI = !!process.env.CI;

export default defineConfig({
    testDir: "./src/tests",

    // Per-test timeout — increase for tests that generate reports or download files
    timeout: 60 * 1000,

    // Per-assertion timeout
    expect: { timeout: 10 * 1000 },

    // Run tests within a file in sequence.
    // Enterprise suites share environments and test data — parallel execution requires
    // isolated storageState per worker (available in the Auth Module, Milestone 2).
    // Upgrade path: set fullyParallel: true and add storageState to each project.
    fullyParallel: false,

    // Fail the build if test.only is accidentally committed
    forbidOnly: isCI,

    // Retry once on CI — intentional divergence from the Playwright default (retries: 0).
    // A single retry distinguishes genuine flakiness from transient infrastructure noise
    // without masking real bugs. See ADR-012 (retries policy).
    retries: isCI ? 1 : 0,

    // Single worker in CI (avoids shared-session conflicts); auto-detect locally
    workers: isCI ? 1 : undefined,

    // Stop after 3 failures in CI to avoid burning minutes on a broken suite
    maxFailures: isCI ? 3 : 0,

    reporter: [
        // HTML report — open manually with: npm run report
        ["html", { open: "never" }],
        // JSON report — used by CI to build run history
        ["json", { outputFile: "test-results.json" }],
        // Blob report — used for shard merging in CI (add when sharding is enabled)
    ],

    use: {
        // Base URL of the application under test.
        // Set URL= in src/config/.env.<%- environments.default %> for your application.
        // Defaults to https://playwright.dev so the sample test runs without configuration.
        baseURL: process.env.URL ?? "https://playwright.dev",

        // Capture screenshot only when a test fails — reduces CI artifact storage
        screenshot: "only-on-failure",

        // Record video only for failing tests — reduces CI artifact storage
        video: "retain-on-failure",

        // Capture Playwright trace on first retry — enables step-by-step replay
        trace: "on-first-retry",

        // Attribute used by getByTestId() — align with your application's data attribute.
        // Change to "data-cy" (Cypress) or "data-qa" to match an existing convention.
        testIdAttribute: "data-testid",
    },

    projects: [
        // ── Primary browser ────────────────────────────────────────────────────
        // Chromium is the default — enterprise internal apps typically support a
        // single browser. See ADR-010 for the cross-browser policy decision.
        {
            name: "chromium",
            use: {
                ...devices["Desktop Chrome"],
                viewport: { width: 1280, height: 720 },
            },
        },

        // ── Optional: cross-browser coverage ───────────────────────────────────
        // Uncomment the projects below and run: npx playwright install
        // Consider running cross-browser only on the release branch in CI.
        //
        // {
        //     name: "firefox",
        //     use: {
        //         ...devices["Desktop Firefox"],
        //         viewport: { width: 1280, height: 720 },
        //     },
        // },
        // {
        //     name: "webkit",
        //     use: {
        //         ...devices["Desktop Safari"],
        //         viewport: { width: 1280, height: 720 },
        //     },
        // },
    ],
});
