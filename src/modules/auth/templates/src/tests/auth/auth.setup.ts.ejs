import { test as setup } from "@playwright/test";
import { LoginPage } from "../../pages/LoginPage";

/**
 * auth.setup.ts — Authentication setup for <%- project.applicationName %>.
 *
 * Runs once before all test projects (via the "setup" project in playwright.config.ts).
 * Performs a UI login, then persists browser state (cookies, localStorage,
 * sessionStorage) to playwright/.auth/user.json so that all test projects can
 * reuse the authenticated session without repeating the login sequence.
 *
 * ── Prerequisites ─────────────────────────────────────────────────────────────
 * 1. Update LoginPage locators in src/pages/LoginPage.ts
 * 2. Implement LoginPage.expectLoginSuccess() — currently throws intentionally.
 *    Add an assertion that confirms authenticated state (URL change, heading, etc.)
 * 3. Set URL, USERID, and PASSWORD in src/config/.env
 *
 * ── Running setup explicitly ──────────────────────────────────────────────────
 *   npx playwright test src/tests/auth/auth.setup.ts
 *
 * ── Running all tests (setup runs automatically first) ───────────────────────
 *   npm test
 *
 * Generated by pw-gen v<%- generator.version %>
 */

const AUTH_STATE_PATH = "playwright/.auth/user.json";

setup("authenticate as default user", async ({ page }, testInfo) => {
    const loginPage = new LoginPage(page, testInfo);

    await loginPage.open();
    await loginPage.expectOnLoginPage();
    await loginPage.loginWithEnvCredentials();

    // Verifies the session is valid before the state is persisted.
    // TODO: implement LoginPage.expectLoginSuccess() for your application.
    await loginPage.expectLoginSuccess();

    // Persist cookies, localStorage, and sessionStorage to disk.
    // All test projects will load this file via storageState in playwright.config.ts.
    await page.context().storageState({ path: AUTH_STATE_PATH });
});
