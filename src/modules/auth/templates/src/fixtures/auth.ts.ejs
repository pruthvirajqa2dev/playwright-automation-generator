import { test as base, mergeTests } from "@playwright/test";
import * as fs from "fs";
import * as path from "path";
import { test as coreTest } from "./test";

/**
 * auth.ts — Auth-aware fixture for <%- project.applicationName %>.
 *
 * Merges the core fixture set (loginPage, _testLifecycle) with an auth-guard
 * fixture (_authGuard) that validates playwright/.auth/user.json exists before
 * each test executes. Import { test, expect } from this file in all tests that
 * require authentication, instead of from fixtures/test.ts.
 *
 * Usage:
 *   import { test, expect } from "../../fixtures/auth";
 *
 * ── mergeTests() pattern ──────────────────────────────────────────────────────
 * The core fixture set and the auth fixture set are independent — each extends
 * the Playwright base separately, then combined here with mergeTests(). This is
 * the Playwright-idiomatic pattern for composing fixtures from separate modules.
 * See: https://playwright.dev/docs/api/class-test#test-merge-tests
 *
 * Generated by pw-gen v<%- generator.version %>
 */

type AuthFixtures = {
    /**
     * Auto fixture — verifies playwright/.auth/user.json exists before each test.
     * Fails fast with an actionable message if auth.setup.ts has not been run.
     */
    _authGuard: void;
};

const authBase = base.extend<AuthFixtures>({
    _authGuard: [
        async ({}, use) => {
            const authFile = path.resolve("playwright/.auth/user.json");
            if (!fs.existsSync(authFile)) {
                throw new Error(
                    [
                        `Auth state not found: ${authFile}`,
                        `Run the auth setup first:`,
                        `  npx playwright test src/tests/auth/auth.setup.ts`,
                        `Then run all tests normally:`,
                        `  npm test`,
                    ].join("\n")
                );
            }
            await use();
        },
        { auto: true },
    ],
});

// Merge core fixtures (loginPage, _testLifecycle) with auth fixtures (_authGuard).
// The combined test object carries all fixtures from both independent sets.
export const test = mergeTests(coreTest, authBase);
export { expect } from "@playwright/test";
export type { Page, Locator, TestInfo, BrowserContext } from "@playwright/test";
